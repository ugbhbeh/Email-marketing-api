

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  campaigns     Campaign[]       
  customers     Customer[] 
}

model Customer {
  id            String         @id @default(uuid())
  email         String        
  name          String?

  userId        String
  user          User        @relation(fields: [userId], references: [id])

  campaign      Campaign[]     @relation("CampaignCustomers")
  @@unique([email, userId])
}

model Campaign{
  id           String         @id @default(uuid())
  name         String    
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt     
  
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  
  customers  Customer[]  @relation("CampaignCustomers")
}