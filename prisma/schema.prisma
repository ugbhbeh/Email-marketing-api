

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  campaigns     Campaign[]       
  customers     Customer[] 
  MailLog       MailLog []

}

model Customer {
  id            String         @id @default(uuid())
  email         String        
  name          String?

  userId        String
  user          User           @relation(fields: [userId], references: [id])
 
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  campaign      Campaign[]     @relation("CampaignCustomers")
  maillog       MailLog []
  
  @@unique([email, userId])
}

model MailLog {
  id          String    @id @default(uuid())
  subject     String
  message     String
  sentAt      DateTime  @default(now())

  
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id])

  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])

  status      String    @default("SENT") 
  error       String?   
}


model Campaign{
  id           String           @id @default(uuid())
  name         String    
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt     
  
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  
  customers    Customer[]       @relation("CampaignCustomers")
  maillog      MailLog []
}